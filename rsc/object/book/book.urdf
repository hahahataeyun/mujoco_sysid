<?xml version="1.0"?>
<robot name="book" xmlns:mujoco="https://mujoco.org/schema/mujoco">
  <mujoco>
    <compiler meshdir="./" />
    <geom link="book" 
          friction="1.5 0.01 0.001" 
          condim="3" 
          solref="0.02 1" 
          solimp="0.9 0.95 0.001" />
  </mujoco>

  <link name="book">
    <visual>
      <origin xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="book.obj" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="book.obj" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/> 
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
</robot>